{
  "name": "agent-toolkit",
  "interface": {
    "displayName": "Agent Toolkit"
  },
  "plugins": [
    {
      "name": "agent-toolkit",
      "source": {
        "source": "url",
        "url": "https://github.com/RollRollRoll/agent-toolkit.git",
        "ref": "main"
      },
      "policy": {
        "installation": "AVAILABLE",
        "authentication": "ON_INSTALL"
      },
      "category": "Productivity"
    },
    {
      "name": "ssh-mcp",
      "source": {
        "source": "local",
        "path": "./mcps/ssh-mcp"
      },
      "policy": {
        "installation": "AVAILABLE",
        "authentication": "ON_INSTALL"
      },
      "category": "Productivity"
    }
  ]
}
